# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_NAME=Learnixo API
APP_URL=http://localhost:4000
CLIENT_URL=http://localhost:8081

# ─── Database (PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql://learnixo:learnixo@localhost:5434/learnixo?schema=public

# ─── Redis (optional cache) ───────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Auth ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
EMAIL_VERIFICATION_EXPIRES_MIN=30
PASSWORD_RESET_EXPIRES_MIN=30

# ─── Rate limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# ─── Uploads ──────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=25
UPLOAD_DIR=src/storage/uploads

# ─── Cloudinary (prepare — leave empty until wired) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── AI providers (prepare only) ──────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Email (prepare — console transport in dev) ───────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Learnixo <noreply@learnixo.app>
